{
  "name": "industry-ai-news-plugin",
  "displayName": "Industry AI News",
  "version": "0.0.1",
  "description": "AI-powered Chrome extension for industry news summaries and alerts.",
  "author": "",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "test": "vitest run",
    "db:local:up": "bash scripts/db-local-up.sh",
    "db:deploy": "bash scripts/db-deploy-supabase.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "plasmo": "0.90.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "3.4.1"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.260",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "10.4.17",
    "jsdom": "^29.0.2",
    "postcss": "8.4.33",
    "prettier": "3.2.4",
    "typescript": "5.3.3",
    "vitest": "2.1.0"
  },
  "manifest": {
    "icons": {
      "16": "~assets/16.png",
      "32": "~assets/16.png",
      "48": "~assets/48.png",
      "64": "~assets/48.png",
      "128": "~assets/128.png"
    },
    "action": {
      "default_icon": {
        "16": "~assets/16.png",
        "32": "~assets/16.png",
        "48": "~assets/48.png",
        "64": "~assets/48.png",
        "128": "~assets/128.png"
      }
    },
    "permissions": [
      "sidePanel",
      "storage",
      "alarms",
      "notifications"
    ],
    "host_permissions": [
      "https://*/*"
    ]
  }
}
