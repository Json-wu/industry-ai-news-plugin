# ========== 扩展构建（Plasmo，复制本文件为 `.env`）==========
# anon 可打进扩展包；切勿把 service_role 放入扩展或提交到 Git。

# Supabase → Project Settings → API
PLASMO_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
PLASMO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Authentication → URL configuration → Redirect URLs 增加：
#   chrome-extension://<扩展ID>/options.html

# ========== Supabase Edge Functions（在 Dashboard → Edge Functions → Secrets 配置，不进 .env）==========
#
# 摘要 summarize-article
#   DEEPSEEK_API_KEY           必填
#   DEEPSEEK_MODEL             可选，默认 deepseek-chat
#   DEEPSEEK_API_BASE          可选
#   SUPABASE_SERVICE_ROLE_KEY  必填（写 article_summary_cache / user_llm_usage_daily）
#   SUMMARY_CACHE_TTL_HOURS    可选，默认 168（7 天）
#   SUMMARY_DAILY_LLM_ITEMS_PER_USER 可选，默认 120（每用户每日计入 LLM 的条目数上限）
#
# 邮件简报 send-news-email-digest
#   RESEND_API_KEY
#   EMAIL_FROM                 可选
#   EMAIL_DIGEST_CRON_SECRET   GitHub Actions 请求头 X-Cron-Secret 须一致
#   SUPABASE_SERVICE_ROLE_KEY
#   EMAIL_UNSUBSCRIBE_SECRET   可选；设置后邮件内包含退订链接（与 email-unsubscribe 共用）
#
# 退订 email-unsubscribe
#   EMAIL_UNSUBSCRIBE_SECRET   与邮件简报中签名一致
#   SUPABASE_SERVICE_ROLE_KEY

# ========== GitHub Actions（仓库 Settings → Secrets and variables → Actions）==========
#
# 邮件定时：.github/workflows/email-digest.yml
#   EMAIL_DIGEST_URL          https://<ref>.supabase.co/functions/v1/send-news-email-digest
#   EMAIL_DIGEST_CRON_SECRET  与 Edge Secret EMAIL_DIGEST_CRON_SECRET 相同
